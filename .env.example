# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE INTEGRATION (Optional)
# If configured, every generated website is synced to a multi-tenant Supabase database.
# Configure these in the AI Studio Secrets / Environment Variables panel.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GITHUB INTEGRATION (Optional Fallback / Fixed Token)
# If configured, clients can publish their sites directly to GitHub Pages without entering their own API token.
GITHUB_TOKEN=

# RENDER INTEGRATION (Optional Fixed API Key)
# If configured, deployments to Render can use this fixed API key instead of requiring one from the user.
RENDER_API_KEY_FIXED=
